<!DOCTYPE html>
<html lang="tr" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#070C1A" />
    <title>@ViewData["Title"] – SemptomAnaliz</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fontlar -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <!-- Bootstrap & İkonlar -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- SweetAlert2 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />

    <!-- Uygulama stilleri -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<nav class="sa-navbar">
    <div class="container d-flex align-items-center justify-content-between py-2">

        <a class="sa-brand" asp-controller="Home" asp-action="Index">
            <i class="bi bi-heart-pulse-fill sa-brand-icon"></i>
            <span class="sa-brand-text">Semptom<strong>Analiz</strong></span>
        </a>

        <button class="navbar-toggler d-lg-none border-0" type="button"
                data-bs-toggle="collapse" data-bs-target="#mainNav"
                style="color:var(--sa-muted)">
            <i class="bi bi-list fs-4"></i>
        </button>

        <div class="collapse navbar-collapse d-lg-flex align-items-center gap-1" id="mainNav">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <ul class="navbar-nav d-flex flex-row gap-1 me-auto mb-0">
                    <li class="nav-item">
                        <a class="sa-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                           asp-controller="Home" asp-action="Dashboard">
                            <i class="bi bi-grid-1x2"></i><span>Panel</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="sa-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Analiz" ? "active" : "")"
                           asp-controller="Analiz" asp-action="Yeni">
                            <i class="bi bi-plus-circle"></i><span>Yeni Analiz</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="sa-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Gecmis" ? "active" : "")"
                           asp-controller="Gecmis" asp-action="Index">
                            <i class="bi bi-clock-history"></i><span>Geçmiş</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="sa-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Profil" ? "active" : "")"
                           asp-controller="Profil" asp-action="Index">
                            <i class="bi bi-person-circle"></i><span>Profilim</span>
                        </a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item">
                            <a class="sa-nav-link sa-nav-admin @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")"
                               asp-controller="Admin" asp-action="Index">
                                <i class="bi bi-shield-check"></i><span>Admin</span>
                            </a>
                        </li>
                    }
                </ul>
                <div class="d-flex align-items-center gap-2 ms-3">
                    <div class="sa-user-chip">
                        <i class="bi bi-person-fill" style="color:var(--sa-primary)"></i>
                        @(User.FindFirst("GivenName")?.Value ?? User.Identity!.Name?.Split('@')[0])
                    </div>
                    <form id="cikisForm" asp-controller="Hesap" asp-action="Cikis" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="button" id="cikisBtn" class="btn btn-sm btn-ghost" title="Çıkış Yap">
                            <i class="bi bi-box-arrow-right"></i>
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div class="d-flex align-items-center gap-2 ms-auto">
                    <a class="sa-nav-link" asp-controller="Hesap" asp-action="Giris">Giriş Yap</a>
                    <a class="btn btn-primary btn-sm px-3" asp-controller="Hesap" asp-action="Kayit">
                        <i class="bi bi-lightning-charge-fill me-1"></i>Ücretsiz Başla
                    </a>
                </div>
            }
        </div>

    </div>
</nav>

<main>
    @RenderBody()
</main>

<footer class="sa-footer mt-5">
    <div class="container text-center py-4">
        <p class="mb-0 small">
            <i class="bi bi-heart-pulse" style="color:var(--sa-primary)"></i>
            <strong style="color:var(--sa-text-sec)">SemptomAnaliz</strong>
            <span style="color:var(--sa-text-sec)">&nbsp;&copy; @DateTime.Now.Year &mdash;
            Bu sistem yalnızca bilgilendirme amaçlıdır; tıbbi tavsiye yerine geçmez.</span>
        </p>
    </div>
</footer>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<!-- SweetAlert2 -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<!-- SweetAlert2 — Karanlık Tema Yapılandırması -->
<script>
    const SwalDark = Swal.mixin({
        background:  '#0D1628',
        color:       '#EEF2FF',
        customClass: {
            popup:         'sa-swal-popup',
            confirmButton: 'sa-swal-btn-confirm',
            cancelButton:  'sa-swal-btn-cancel'
        },
        buttonsStyling: false
    });
    window.SwalDark = SwalDark;
</script>

<!-- TempData: Genel başarı tostu -->
@if (TempData["Basarili"] != null)
{
    <script>
    document.addEventListener('DOMContentLoaded', () => {
        SwalDark.fire({
            icon: 'success',
            title: 'Başarılı',
            text: '@Html.Raw(TempData["Basarili"]?.ToString()?.Replace("'", "\\'"))',
            toast: true, position: 'top-end',
            showConfirmButton: false,
            timer: 3500, timerProgressBar: true,
            iconColor: '#34D399'
        });
    });
    </script>
}

<!-- TempData: Genel hata tostu -->
@if (TempData["Hata"] != null)
{
    <script>
    document.addEventListener('DOMContentLoaded', () => {
        SwalDark.fire({
            icon: 'error',
            title: 'Hata',
            text: '@Html.Raw(TempData["Hata"]?.ToString()?.Replace("'", "\\'"))',
            toast: true, position: 'top-end',
            showConfirmButton: false,
            timer: 4500, timerProgressBar: true,
            iconColor: '#F87171'
        });
    });
    </script>
}

<!-- TempData: Giriş başarılı -->
@if (TempData["GirisBasarili"] != null)
{
    <script>
    document.addEventListener('DOMContentLoaded', () => {
        SwalDark.fire({
            icon: 'success',
            title: 'Hoş Geldiniz 👋',
            text: 'Merhaba, @Html.Raw(TempData["GirisBasarili"]?.ToString()?.Replace("'", "\\'"))!',
            toast: true, position: 'top-end',
            showConfirmButton: false,
            timer: 3000, timerProgressBar: true,
            iconColor: '#34D399'
        });
    });
    </script>
}

<!-- TempData: Kayıt başarılı — karşılama modali -->
@if (TempData["KayitBasarili"] != null)
{
    <script>
    document.addEventListener('DOMContentLoaded', () => {
        SwalDark.fire({
            icon: 'success',
            title: 'Hesabınız Oluşturuldu!',
            html: `<span style="color:var(--sa-text-sec)">Hoş geldin, <b style="color:var(--sa-primary-light)">@Html.Raw(TempData["KayitBasarili"]?.ToString()?.Replace("'", "\\'"))</b>!<br>Sağlık analizinize hemen başlayabilirsiniz.</span>`,
            confirmButtonText: '<i class="bi bi-arrow-right me-1"></i>Başla',
            iconColor: '#34D399'
        });
    });
    </script>
}

<!-- TempData: Analiz tamamlandı -->
@if (TempData["AnalizTamamlandi"] != null)
{
    <script>
    document.addEventListener('DOMContentLoaded', () => {
        setTimeout(() => {
            SwalDark.fire({
                icon: 'success',
                title: 'Analiz Tamamlandı',
                text: 'Sonuçlarınız aşağıda hazır.',
                toast: true, position: 'top-end',
                showConfirmButton: false,
                timer: 2800, timerProgressBar: true,
                iconColor: '#34D399'
            });
        }, 600);
    });
    </script>
}

<!-- Çıkış onay diyaloğu -->
<script>
document.addEventListener('DOMContentLoaded', () => {
    const cikisBtn = document.getElementById('cikisBtn');
    if (cikisBtn) {
        cikisBtn.addEventListener('click', () => {
            SwalDark.fire({
                icon: 'question',
                title: 'Çıkış Yapılsın mı?',
                html: '<span style="color:var(--sa-text-sec)">Hesabınızdan çıkış yapmak istediğinize emin misiniz?</span>',
                showCancelButton: true,
                confirmButtonText: '<i class="bi bi-box-arrow-right me-1"></i>Çıkış Yap',
                cancelButtonText: 'İptal',
                iconColor: 'var(--sa-primary-light)',
                reverseButtons: true
            }).then(result => {
                if (result.isConfirmed)
                    document.getElementById('cikisForm').submit();
            });
        });
    }
});
</script>

<!-- Uygulama JS -->
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
